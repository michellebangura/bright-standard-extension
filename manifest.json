{
  "manifest_version": 3,
  "name": "Bright Standard",
  "version": "1.0.0",
  "description": "See the real quality of any TPT lesson — scored against the Five Checks framework before you buy.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.teacherspayteachers.com/*",
    "https://gexxdsiowglhrxkkvsrv.supabase.co/*"
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.teacherspayteachers.com/Product/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
